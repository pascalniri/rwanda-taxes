{
  "name": "global-taxes",
  "version": "1.3.0",
  "bin": {
    "global-taxes": "dist/cli.js"
  },
  "description": "Universal dynamic tax information engine for global countries",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": [
    "taxes",
    "rwanda",
    "global",
    "africa",
    "kenya",
    "usa",
    "uk",
    "tax-rates",
    "api"
  ],
  "author": "Pascal Niri",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pascalniri/global-taxes.git"
  },
  "bugs": {
    "url": "https://github.com/pascalniri/global-taxes/issues"
  },
  "homepage": "https://github.com/pascalniri/global-taxes#readme",
  "type": "commonjs",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
